{
  "name": "full_load_pipeline",
  "properties": {
    "activities": [
      {
        "name": "foreach_full_tables",
        "type": "ForEach",
        "typeProperties": {
          "items": {
            "value": "@pipeline().parameters.Fullloadtables",
            "type": "Expression"
          },
          "isSequential": false,
          "batchCount": 5,
          "activities": [
            {
              "name": "copy_onprem_to_bronze",
              "type": "Copy",
              "policy": {
                "retry": 3,
                "retryIntervalInSeconds": 60
              },
              "typeProperties": {
                "source": {
                  "type": "SqlServerSource"
                },
                "sink": {
                  "type": "DelimitedTextSink",
                  "storeSettings": {
                    "type": "AzureBlobStorageWriteSettings"
                  },
                  "formatSettings": {
                    "type": "DelimitedTextWriteSettings",
                    "quoteAllText": true,
                    "fileExtension": ".csv"
                  }
                },
                "translator": {
                  "type": "TabularTranslator",
                  "typeConversion": true
                }
              },
              "inputs": [
                {
                  "referenceName": "ds_sql_onprem",
                  "type": "DatasetReference",
                  "parameters": {
                    "schema": {
                      "value": "@item().sourceSchema",
                      "type": "Expression"
                    },
                    "tablename": {
                      "value": "@item().sourceTableName",
                      "type": "Expression"
                    }
                  }
                }
              ],
              "outputs": [
                {
                  "referenceName": "ds_bronze_layer",
                  "type": "DatasetReference",
                  "parameters": {
                    "filename": {
                      "value": "@concat(item().sourceSchema,'_',item().sourceTableName,'.csv')",
                      "type": "Expression"
                    }
                  }
                }
              ]
            }
          ]
        }
      }
    ],
    "parameters": {
      "Fullloadtables": {
        "type": "array"
      }
    }
  },
  "type": "Microsoft.DataFactory/factories/pipelines"
}