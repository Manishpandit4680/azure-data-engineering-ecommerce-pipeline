{
  "name": "gold_layer_pipeline",
  "properties": {
    "activities": [
      {
        "name": "foreach_gold_notebooks",
        "type": "ForEach",
        "typeProperties": {
          "items": {
            "value": "@pipeline().parameters.goldnotebooklist",
            "type": "Expression"
          },
          "isSequential": false,
          "batchCount": 2,
          "activities": [
            {
              "name": "run_gold_notebook",
              "type": "DatabricksNotebook",
              "policy": {
                "retry": 2,
                "retryIntervalInSeconds": 60
              },
              "typeProperties": {
                "notebookPath": {
                  "value": "@item()",
                  "type": "Expression"
                }
              },
              "linkedServiceName": {
                "referenceName": "ls_databricks",
                "type": "LinkedServiceReference"
              }
            }
          ]
        }
      }
    ],
    "parameters": {
      "goldnotebooklist": {
        "type": "array",
        "defaultValue": [
          "/Workspace/Gold/CustomerOrderSummary",
          "/Workspace/Gold/ProductPerformance",
          "/Workspace/Gold/DailySalesSummary",
          "/Workspace/Gold/CategoryWiseSales"
        ]
      }
    }
  },
  "type": "Microsoft.DataFactory/factories/pipelines"
}